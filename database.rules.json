{
  "rules": {
    "votes": {
      ".read": true,
      "$choice": {
        ".write": "($choice === 'yes' || $choice === 'no') && newData.isNumber() && ((!data.exists() && newData.val() === 1) || (data.isNumber() && newData.val() === data.val() + 1))",
        ".validate": "newData.isNumber() && newData.val() >= 0"
      }
    }
  }
}
