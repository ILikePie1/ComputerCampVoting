{
  "rules": {
    ".read": false,
    ".write": false,

    "admins": {
      "$uid": {
        ".read": "auth != null && root.child('admins').child(auth.uid).val() === true",
        ".write": false,
        ".validate": "newData.isBoolean()"
      }
    },

    "scenarios": {
      ".read": true,
      "$scenarioId": {
        ".write": "auth != null && root.child('admins').child(auth.uid).val() === true && $scenarioId.matches(/^([1-9]|1[0-5])$/)",

        "name": {
          ".validate": "!newData.exists() || (newData.isString() && newData.val().matches(/^.{0,80}$/))"
        },

        "description": {
          ".validate": "!newData.exists() || (newData.isString() && newData.val().matches(/^.{0,240}$/))"
        },

        "$other": {
          ".validate": false
        }
      }
    },

    "votes": {
      ".read": "auth != null && root.child('admins').child(auth.uid).val() === true",

      "$scenarioId": {
        "count": {
          ".write": "$scenarioId.matches(/^([1-9]|1[0-5])$/) && ((auth != null && root.child('admins').child(auth.uid).val() === true) || (root.child('scenarios').child($scenarioId).child('name').isString() && root.child('scenarios').child($scenarioId).child('name').val().matches(/.*[^ ].*/) && newData.isNumber() && newData.val() >= 0 && ((!data.exists() && newData.val() === 1) || (data.isNumber() && (newData.val() === data.val() + 1 || newData.val() === data.val() - 1)))))",

          ".validate": "newData.isNumber() && newData.val() >= 0"
        },

        "$other": {
          ".validate": false
        }
      }
    }
  }
}